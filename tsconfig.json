{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "strict": true
  },
  "include": [
    "src/**/*",
    "vite.*.config.mjs",
    "vite.*.config.ts",
    "forge.config.ts",
    "node_modules/@electron-forge/plugin-vite/forge-vite-env.d.ts"
  ]
}
